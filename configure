#!/bin/sh

if [ -d "${HOME}/.cargo/bin" ]; then
  export PATH="${PATH}:${HOME}/.cargo/bin"
fi

CARGO_VERSION="$(cargo --version)"
if [ $? -ne 0 ]; then
  echo "-------------- ERROR: CONFIGURATION FAILED --------------------"
  echo "The cargo command is not available. Install Rust from https://www.rust-lang.org/tools/install"
  echo "---------------------------------------------------------------"
  exit 1
fi
RUSTC_VERSION="$(rustc --version || true)"
echo "using Rust package manager: '${CARGO_VERSION}'"
echo "using Rust compiler: '${RUSTC_VERSION}'"

RBEBELM_PKG_LIBS=""
RBEBELM_WASM_OBJECTS=""
cc_for_check=${CC:-cc}
if "$cc_for_check" --version 2>/dev/null | grep -qi emscripten; then
  RBEBELM_PKG_LIBS=''
  RBEBELM_WASM_OBJECTS='wasm_stubs.o'
else
  case "$(uname -s 2>/dev/null || echo unknown)" in
    Linux*) RBEBELM_PKG_LIBS="-ldl" ;;
    Darwin*) RBEBELM_PKG_LIBS="" ;;
    *) RBEBELM_PKG_LIBS="" ;;
  esac
fi

sed \
  -e "s|@RBEBELM_PKG_LIBS@|${RBEBELM_PKG_LIBS}|g" \
  -e "s|@RBEBELM_WASM_OBJECTS@|${RBEBELM_WASM_OBJECTS}|g" \
  src/Makevars.in > src/Makevars
